    {
      "label": "cmake: configure",
      "type": "shell",
      "command": "cmake --preset windows-vs2022",
      "options": { "cwd": "${workspaceFolder}/demo" },
      "group": "build",
      "presentation": { "reveal": "silent", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "build: Debug",
      "type": "shell",
      "command": "cmake --build build/windows-vs2022 --config Debug",
      "options": { "cwd": "${workspaceFolder}/demo" },
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": "$msCompile",
      "dependsOn": "cmake: configure"
    },

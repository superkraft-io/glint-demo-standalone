{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "GLINT_RENDER_GPU": "ON",
        "GLINT_ENABLE_D3D12": "ON",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "windows-vs2022",
      "inherits": "base",
      "generator": "Visual Studio 17 2022",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "architecture": { "value": "x64", "strategy": "set" }
    },
    {
      "name": "windows-vs2022-debug",
      "inherits": "windows-vs2022",
      "binaryDir": "${sourceDir}/build/windows-vs2022"
    },
    {
      "name": "windows-vs2022-relwithdebinfo",
      "inherits": "windows-vs2022",
      "binaryDir": "${sourceDir}/build/windows-vs2022"
    },
    {
      "name": "macos",
      "inherits": "base",
      "generator": "Ninja",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "binaryDir": "${sourceDir}/build/macos",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "macos-debug",
      "inherits": "macos",
      "binaryDir": "${sourceDir}/build/macos",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "macos-relwithdebinfo",
      "inherits": "macos",
      "binaryDir": "${sourceDir}/build/macos",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "macos-release",
      "inherits": "macos",
      "binaryDir": "${sourceDir}/build/macos",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "ios-sim-base",
      "inherits": "base",
      "generator": "Xcode",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "binaryDir": "${sourceDir}/build/ios-sim",
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "iOS",
        "CMAKE_OSX_SYSROOT": "iphonesimulator",
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "ios-sim-debug",
      "inherits": "ios-sim-base",
      "binaryDir": "${sourceDir}/build/ios-sim",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "linux",
      "inherits": "base",
      "generator": "Ninja",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "binaryDir": "${sourceDir}/build/linux",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "GLINT_RENDER_GPU": "OFF",
        "GLINT_ENABLE_D3D12": "OFF",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "linux-debug",
      "inherits": "linux",
      "binaryDir": "${sourceDir}/build/linux",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "linux-debug-opengl",
      "inherits": "linux",
      "binaryDir": "${sourceDir}/build/linux-opengl",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "GLINT_RENDER_GPU": "ON",
        "GLINT_ENABLE_D3D12": "OFF"
      }
    },
    {
      "name": "linux-relwithdebinfo",
      "inherits": "linux",
      "binaryDir": "${sourceDir}/build/linux",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "linux-release",
      "inherits": "linux",
      "binaryDir": "${sourceDir}/build/linux",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-vs2022",
      "configurePreset": "windows-vs2022",
      "configuration": "Release"
    },
    {
      "name": "windows-vs2022-debug",
      "configurePreset": "windows-vs2022-debug",
      "configuration": "Debug"
    },
    {
      "name": "windows-vs2022-relwithdebinfo",
      "configurePreset": "windows-vs2022-relwithdebinfo",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "macos",
      "configurePreset": "macos"
    },
    {
      "name": "macos-debug",
      "configurePreset": "macos-debug"
    },
    {
      "name": "macos-relwithdebinfo",
      "configurePreset": "macos-relwithdebinfo"
    },
    {
      "name": "macos-release",
      "configurePreset": "macos-release"
    },
    {
      "name": "ios-sim-debug",
      "configurePreset": "ios-sim-debug"
    },
    {
      "name": "ios-sim-release",
      "configurePreset": "ios-sim-debug",
      "configuration": "Release"
    },
    {
      "name": "linux",
      "configurePreset": "linux"
    },
    {
      "name": "linux-debug",
      "configurePreset": "linux-debug"
    },
    {
      "name": "linux-debug-opengl",
      "configurePreset": "linux-debug-opengl"
    },
    {
      "name": "linux-relwithdebinfo",
      "configurePreset": "linux-relwithdebinfo"
    },
    {
      "name": "linux-release",
      "configurePreset": "linux-release"
    }
  ]
}